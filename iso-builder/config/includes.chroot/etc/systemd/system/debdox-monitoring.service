[Unit]
Description=DebDox Monitoring Stack (Prometheus, Grafana, cAdvisor)
After=docker.service
Requires=docker.service

[Service]
Type=exec
WorkingDirectory=/opt/debdox/monitoring
ExecStart=/usr/bin/docker compose up --pull always --remove-orphans
ExecStop=/usr/bin/docker compose down
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=debdox-monitoring

[Install]
WantedBy=multi-user.target
