#!/usr/bin/env bash
# DebDox Installer — runs from the live environment, installs DebDox to disk
set -euo pipefail

[[ $EUID -ne 0 ]] && { echo "Must run as root" >&2; exit 1; }

W() { whiptail "$@" 3>&1 1>&2 2>&3; }
TARGET="/target"

# Partition helper — handles sda1 vs nvme0n1p1 naming
part() { [[ "$1" == *nvme* || "$1" == *mmcblk* ]] && echo "${1}p${2}" || echo "${1}${2}"; }

# ── Banner ────────────────────────────────────────────────────────────────
clear
printf '\n'
printf '  \033[1;36m██████╗ ███████╗██████╗ ██████╗  ██████╗ ██╗  ██╗\033[0m\n'
printf '  \033[1;36m██╔══██╗██╔════╝██╔══██╗██╔══██╗██╔═══██╗╚██╗██╔╝\033[0m\n'
printf '  \033[1;36m██║  ██║█████╗  ██████╔╝██║  ██║██║   ██║ ╚███╔╝ \033[0m\n'
printf '  \033[1;36m██║  ██║██╔══╝  ██╔══██╗██║  ██║██║   ██║ ██╔██╗ \033[0m\n'
printf '  \033[1;36m██████╔╝███████╗██████╔╝██████╔╝╚██████╔╝██╔╝ ██╗\033[0m\n'
printf '  \033[1;36m╚═════╝ ╚══════╝╚═════╝ ╚═════╝  ╚═════╝ ╚═╝  ╚═╝\033[0m\n'
printf '  \033[2mHypervisor Platform — Installer\033[0m\n\n'
sleep 1

# ── 1. Welcome ────────────────────────────────────────────────────────────
W --title " DebDox Installer " --msgbox \
"Welcome to the DebDox installer.\n\
\n\
This wizard will:\n\
\n\
  • Partition the selected disk\n\
  • Install DebDox to disk\n\
  • Install the GRUB bootloader\n\
\n\
On first boot after installation, a setup wizard\n\
will configure the network, admin password and\n\
optional ZFS storage pool.\n\
\n\
WARNING: The selected disk will be completely erased." \
20 64

# ── 2. Disk selection ─────────────────────────────────────────────────────
DISK_ARGS=()
while IFS= read -r line; do
    dev="${line%% *}"
    rest="${line#* }"
    size="${rest%% *}"
    model="${rest#* }"
    [[ "$dev" == loop* || "$dev" == sr* ]] && continue
    DISK_ARGS+=("/dev/$dev" "${size}  ${model}")
done < <(lsblk -dno NAME,SIZE,MODEL 2>/dev/null)

if [[ ${#DISK_ARGS[@]} -eq 0 ]]; then
    W --title " Error " --msgbox "No disks found." 8 40
    exit 1
fi

DISK=$(W --title " Target Disk " \
    --menu "Select the disk to install DebDox on:" \
    16 70 8 "${DISK_ARGS[@]}")

# ── 3. Detect boot mode ───────────────────────────────────────────────────
if [[ -d /sys/firmware/efi ]]; then
    BOOT_MODE="uefi"
    BOOT_LABEL="UEFI"
else
    BOOT_MODE="bios"
    BOOT_LABEL="BIOS (Legacy)"
fi

# ── 4. Confirm ────────────────────────────────────────────────────────────
DISK_SIZE=$(lsblk -dno SIZE "$DISK" 2>/dev/null || echo "?")
DISK_MODEL=$(lsblk -dno MODEL "$DISK" 2>/dev/null || echo "")

W --title " !! WARNING — DISK WILL BE ERASED !!" --yesno \
"All data on the following disk will be permanently lost:\n\
\n\
  Disk  : ${DISK}\n\
  Size  : ${DISK_SIZE}\n\
  Model : ${DISK_MODEL}\n\
  Boot  : ${BOOT_LABEL}\n\
\n\
Proceed with installation?" \
14 64

# ── 5. Partition ──────────────────────────────────────────────────────────
clear
echo "==> [1/6] Partitioning ${DISK}..."
wipefs -a "$DISK" 2>/dev/null || true
partprobe "$DISK" 2>/dev/null || true

if [[ "$BOOT_MODE" == "uefi" ]]; then
    parted -s "$DISK" \
        mklabel gpt \
        mkpart ESP fat32 1MiB 513MiB \
        set 1 esp on \
        mkpart primary ext4 513MiB 100%
    EFI_PART=$(part "$DISK" 1)
    ROOT_PART=$(part "$DISK" 2)
else
    parted -s "$DISK" \
        mklabel gpt \
        mkpart primary 1MiB 2MiB \
        set 1 bios_grub on \
        mkpart primary ext4 2MiB 100%
    ROOT_PART=$(part "$DISK" 2)
fi

partprobe "$DISK"
sleep 1

# ── 6. Format ─────────────────────────────────────────────────────────────
echo "==> [2/6] Formatting partitions..."
[[ "$BOOT_MODE" == "uefi" ]] && mkfs.fat -F32 -n EFI "$EFI_PART" -q
mkfs.ext4 -L debdox-root -q -F "$ROOT_PART"

# ── 7. Mount ──────────────────────────────────────────────────────────────
echo "==> [3/6] Mounting target..."
mkdir -p "$TARGET"
mount "$ROOT_PART" "$TARGET"
if [[ "$BOOT_MODE" == "uefi" ]]; then
    mkdir -p "${TARGET}/boot/efi"
    mount "$EFI_PART" "${TARGET}/boot/efi"
fi

# ── 8. Copy live system to disk ───────────────────────────────────────────
echo "==> [4/6] Copying system to disk (this takes a few minutes)..."
rsync -aHAX \
    --exclude="/dev/*" \
    --exclude="/proc/*" \
    --exclude="/sys/*" \
    --exclude="/tmp/*" \
    --exclude="/run/*" \
    --exclude="/mnt/*" \
    --exclude="/media/*" \
    --exclude="/target/*" \
    --exclude="/lost+found" \
    / "${TARGET}/"

# ── 9. Configure the installed system ────────────────────────────────────
echo "==> [5/6] Configuring installed system..."

# fstab
ROOT_UUID=$(blkid -s UUID -o value "$ROOT_PART")
{
    echo "UUID=${ROOT_UUID}  /        ext4  errors=remount-ro  0  1"
    if [[ "$BOOT_MODE" == "uefi" ]]; then
        EFI_UUID=$(blkid -s UUID -o value "$EFI_PART")
        echo "UUID=${EFI_UUID}   /boot/efi  vfat  umask=0077         0  2"
    fi
    echo "tmpfs            /tmp     tmpfs  defaults,nosuid,nodev  0  0"
} > "${TARGET}/etc/fstab"

# Hostname
echo "debdox" > "${TARGET}/etc/hostname"
cat > "${TARGET}/etc/hosts" <<'HOSTS'
127.0.0.1   localhost
127.0.1.1   debdox
::1         localhost ip6-localhost ip6-loopback
HOSTS

# Bind-mount kernel filesystems for chroot operations
mount --bind /dev  "${TARGET}/dev"
mount -t proc  proc  "${TARGET}/proc"
mount -t sysfs sysfs "${TARGET}/sys"
mount --bind /run  "${TARGET}/run"
if [[ "$BOOT_MODE" == "uefi" ]]; then
    mount --bind /sys/firmware/efi/efivars \
        "${TARGET}/sys/firmware/efi/efivars" 2>/dev/null || true
fi

# Stub update-grub so kernel hooks don't fail during chroot operations.
# grub-mkconfig cannot probe the disk correctly here; we write grub.cfg
# manually after grub-install, which overwrites any auto-generated file.
if [[ -f "${TARGET}/usr/sbin/update-grub" ]]; then
    cp "${TARGET}/usr/sbin/update-grub" "${TARGET}/usr/sbin/update-grub.bak"
    printf '#!/bin/sh\nexit 0\n' > "${TARGET}/usr/sbin/update-grub"
fi

# Remove live-boot packages so the installed system boots normally
chroot "$TARGET" apt-get purge -y --auto-remove \
    live-boot live-boot-initramfs-tools \
    live-config live-config-systemd \
    live-tools 2>/dev/null || true

# Write a clean GRUB config before generating grub.cfg
cat > "${TARGET}/etc/default/grub" <<GRUBDEFAULT
GRUB_DEFAULT=0
GRUB_TIMEOUT=3
GRUB_DISTRIBUTOR="DebDox"
GRUB_CMDLINE_LINUX_DEFAULT=""
GRUB_CMDLINE_LINUX="root=UUID=${ROOT_UUID} ro quiet"
GRUB_DISABLE_OS_PROBER=true
GRUBDEFAULT

# Regenerate initramfs without live hooks
chroot "$TARGET" update-initramfs -u -k all

# ── 10. Install GRUB ──────────────────────────────────────────────────────
echo "==> [6/6] Installing GRUB bootloader..."
if [[ "$BOOT_MODE" == "uefi" ]]; then
    chroot "$TARGET" grub-install \
        --target=x86_64-efi \
        --efi-directory=/boot/efi \
        --bootloader-id=DebDox \
        --no-nvram \
        --recheck
    # Ensure fallback EFI path exists for firmware that ignores BootOrder
    mkdir -p "${TARGET}/boot/efi/EFI/BOOT"
    cp "${TARGET}/boot/efi/EFI/DebDox/grubx64.efi" \
       "${TARGET}/boot/efi/EFI/BOOT/BOOTX64.EFI" 2>/dev/null || true
else
    # Run from live system with explicit boot-directory so GRUB modules
    # are copied from live's grub-pc-bin into the target's /boot/grub/
    grub-install \
        --target=i386-pc \
        --boot-directory="${TARGET}/boot" \
        --recheck \
        "$DISK"
fi

# Find the installed kernel version
KERNEL_VER=$(ls "${TARGET}/boot/vmlinuz-"* 2>/dev/null \
    | sort -V | tail -1 | sed 's|.*/vmlinuz-||')

[[ -n "$KERNEL_VER" ]] \
    || { echo "ERROR: no kernel found in ${TARGET}/boot/"; exit 1; }

echo "    kernel: ${KERNEL_VER}"

# Write grub.cfg directly — avoids grub-mkconfig chroot environment issues
mkdir -p "${TARGET}/boot/grub"
cat > "${TARGET}/boot/grub/grub.cfg" <<GRUBCFG
set default=0
set timeout=3

insmod part_gpt
insmod part_msdos
insmod ext2
insmod gzio
insmod search
insmod search_fs_uuid

menuentry "DebDox" {
    search --no-floppy --fs-uuid --set=root ${ROOT_UUID}
    linux  /boot/vmlinuz-${KERNEL_VER} root=UUID=${ROOT_UUID} ro quiet
    initrd /boot/initrd.img-${KERNEL_VER}
}
GRUBCFG

echo "    grub.cfg written (root UUID=${ROOT_UUID})"

# Restore update-grub (needed for future kernel upgrades on installed system)
if [[ -f "${TARGET}/usr/sbin/update-grub.bak" ]]; then
    mv "${TARGET}/usr/sbin/update-grub.bak" "${TARGET}/usr/sbin/update-grub"
fi

# ── Unmount ───────────────────────────────────────────────────────────────
umount "${TARGET}/run"                          2>/dev/null || true
umount "${TARGET}/sys/firmware/efi/efivars"     2>/dev/null || true
umount "${TARGET}/sys"                          2>/dev/null || true
umount "${TARGET}/proc"                         2>/dev/null || true
umount "${TARGET}/dev"                          2>/dev/null || true
[[ "$BOOT_MODE" == "uefi" ]] && umount "${TARGET}/boot/efi" 2>/dev/null || true
umount "$TARGET"

# ── Done ──────────────────────────────────────────────────────────────────
clear
printf '\n'
printf '  \033[1;32m✓  DebDox installed successfully!\033[0m\n\n'
printf '  Remove the installation media, then press Enter to reboot.\n\n'
read -r
reboot
