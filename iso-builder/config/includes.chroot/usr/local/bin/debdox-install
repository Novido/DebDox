#!/usr/bin/env bash
# DebDox Installer (graphical TUI) — Proxmox-style single-flow installer.
# Collects every setting up front, applies it to disk, reboots into a
# fully configured system. No first-boot wizard.
set -euo pipefail

[[ $EUID -ne 0 ]] && { echo "Must run as root" >&2; exit 1; }

# Delegate to the text-mode installer when requested on the kernel cmdline
if grep -qw 'debdox\.installer=text' /proc/cmdline 2>/dev/null; then
    exec /usr/local/bin/debdox-install-text
fi

source /usr/local/lib/debdox/install-lib.sh

W() { whiptail "$@" 3>&1 1>&2 2>&3; }

# ── Banner ────────────────────────────────────────────────────────────────
clear
printf '\n'
printf '  \033[1;36m██████╗ ███████╗██████╗ ██████╗  ██████╗ ██╗  ██╗\033[0m\n'
printf '  \033[1;36m██╔══██╗██╔════╝██╔══██╗██╔══██╗██╔═══██╗╚██╗██╔╝\033[0m\n'
printf '  \033[1;36m██║  ██║█████╗  ██████╔╝██║  ██║██║   ██║ ╚███╔╝ \033[0m\n'
printf '  \033[1;36m██║  ██║██╔══╝  ██╔══██╗██║  ██║██║   ██║ ██╔██╗ \033[0m\n'
printf '  \033[1;36m██████╔╝███████╗██████╔╝██████╔╝╚██████╔╝██╔╝ ██╗\033[0m\n'
printf '  \033[1;36m╚═════╝ ╚══════╝╚═════╝ ╚═════╝  ╚═════╝ ╚═╝  ╚═╝\033[0m\n'
printf '  \033[2mHypervisor Platform — Installer\033[0m\n\n'
sleep 1

# ── Welcome ───────────────────────────────────────────────────────────────
W --title " DebDox Installer " --msgbox \
"Welcome to the DebDox installer.\n\
\n\
This wizard collects all settings, then installs DebDox\n\
to disk and reboots into a ready-to-use system:\n\
\n\
  • Target disk\n\
  • Location, time zone and keyboard\n\
  • Administration password\n\
  • Management network (hostname, IP, gateway, DNS)\n\
  • Optional ZFS storage pool\n\
\n\
WARNING: The selected disk will be completely erased." 20 64

# ── 1. Target disk ────────────────────────────────────────────────────────
DISK_ARGS=()
while IFS= read -r line; do
    dev="${line%% *}"; rest="${line#* }"; size="${rest%% *}"; model="${rest#* }"
    [[ "$dev" == loop* || "$dev" == sr* ]] && continue
    DISK_ARGS+=("/dev/$dev" "${size}  ${model}")
done < <(lsblk -dno NAME,SIZE,MODEL 2>/dev/null)

[[ ${#DISK_ARGS[@]} -eq 0 ]] && { W --title " Error " --msgbox "No disks found." 8 40; exit 1; }

DISK=$(W --title " Target Disk " \
    --menu "Select the disk to install DebDox on:" 16 70 8 "${DISK_ARGS[@]}")

if [[ -d /sys/firmware/efi ]]; then BOOT_MODE="uefi"; BOOT_LABEL="UEFI"
else BOOT_MODE="bios"; BOOT_LABEL="BIOS (Legacy)"; fi

# ── 2. Location & Time Zone ───────────────────────────────────────────────
LOCALE=$(W --title " Language / Locale " \
    --menu "Select the system language and locale:" 20 64 11 \
    "en_US.UTF-8" "English (United States)" \
    "en_GB.UTF-8" "English (United Kingdom)" \
    "sv_SE.UTF-8" "Swedish (Sweden)" \
    "nb_NO.UTF-8" "Norwegian Bokmal (Norway)" \
    "da_DK.UTF-8" "Danish (Denmark)" \
    "fi_FI.UTF-8" "Finnish (Finland)" \
    "de_DE.UTF-8" "German (Germany)" \
    "fr_FR.UTF-8" "French (France)" \
    "es_ES.UTF-8" "Spanish (Spain)" \
    "it_IT.UTF-8" "Italian (Italy)" \
    "nl_NL.UTF-8" "Dutch (Netherlands)") || LOCALE="en_US.UTF-8"
[[ -z "$LOCALE" ]] && LOCALE="en_US.UTF-8"

KEYMAP=$(W --title " Keyboard Layout " \
    --menu "Select the keyboard layout:" 20 64 11 \
    "us" "English (US)" "gb" "English (UK)" "se" "Swedish" \
    "no" "Norwegian" "dk" "Danish" "fi" "Finnish" \
    "de" "German" "fr" "French" "es" "Spanish" \
    "it" "Italian" "nl" "Dutch") || KEYMAP="us"
[[ -z "$KEYMAP" ]] && KEYMAP="us"
# Apply now so the admin password is typed with the chosen layout
loadkeys "$KEYMAP" 2>/dev/null || true

TZSEL=$(W --title " Time Zone " \
    --menu "Select the system time zone:" 22 64 14 \
    "Europe/Stockholm" "Sweden" "Europe/Oslo" "Norway" \
    "Europe/Copenhagen" "Denmark" "Europe/Helsinki" "Finland" \
    "Europe/Berlin" "Germany / Central Europe" "Europe/London" "United Kingdom" \
    "Europe/Paris" "France" "Europe/Madrid" "Spain" \
    "Europe/Rome" "Italy" "Europe/Amsterdam" "Netherlands" \
    "America/New_York" "US Eastern" "America/Chicago" "US Central" \
    "America/Los_Angeles" "US Pacific" "UTC" "Coordinated Universal Time" \
    "Other" "Enter manually...") || TZSEL="UTC"
if [[ "$TZSEL" == "Other" ]]; then
    TIMEZONE=$(W --title " Time Zone " --inputbox \
        "Enter the time zone (e.g. Europe/Stockholm):" 9 62 "UTC")
else
    TIMEZONE="$TZSEL"
fi
[[ -f "/usr/share/zoneinfo/${TIMEZONE}" ]] || TIMEZONE="UTC"

# ── 3. Administration password ────────────────────────────────────────────
ADMIN_USER=$(W --title " Admin Account " \
    --inputbox "Admin username for the web UI:" 9 62 "admin")
[[ -z "$ADMIN_USER" ]] && ADMIN_USER="admin"

while true; do
    PASS1=$(W --title " Admin Password " \
        --passwordbox "Set the password for '${ADMIN_USER}'\n(also the root console password):" 10 62)
    PASS2=$(W --title " Admin Password " --passwordbox "Confirm password:" 9 62)
    [[ -n "$PASS1" && "$PASS1" == "$PASS2" ]] && break
    W --title " Error " --msgbox "Passwords do not match or are empty.\nPlease try again." 9 55
done
ADMIN_PASS="$PASS1"

# ── 4. Management network ─────────────────────────────────────────────────
HOSTNAME=$(W --title " Hostname " --inputbox \
    "System hostname (FQDN or short name):" 9 62 "debdox.local")
[[ -z "$HOSTNAME" ]] && HOSTNAME="debdox.local"

IFACE_ARGS=()
while IFS= read -r iface; do
    mac=$(cat "/sys/class/net/$iface/address" 2>/dev/null || echo "??:??:??:??:??:??")
    IFACE_ARGS+=("$iface" "[$mac]")
done < <(ls /sys/class/net/ | grep -Ev '^(lo|docker|virbr|veth|vmbr|bond|dummy)')
[[ ${#IFACE_ARGS[@]} -eq 0 ]] && { W --title " Error " --msgbox "No network interfaces found." 8 50; exit 1; }

NET_IFACE=$(W --title " Network Interface " \
    --menu "Select the management network interface:" 16 62 8 "${IFACE_ARGS[@]}")

DHCP_CIDR=$(ip -4 addr show "$NET_IFACE" 2>/dev/null | awk '/inet /{print $2}' | head -1 || true)
DHCP_ADDR="${DHCP_CIDR%%/*}"; DHCP_PREFIX="${DHCP_CIDR##*/}"
DHCP_GW=$(ip route 2>/dev/null | awk '/^default/{print $3}' | head -1 || true)

STATIC_CIDR=$(W --title " IP Address " --inputbox \
    "Static IP address in CIDR notation:\n(e.g. 192.168.1.100/24)" \
    11 62 "${DHCP_ADDR:-192.168.1.100}/${DHCP_PREFIX:-24}")
GATEWAY=$(W --title " Default Gateway " --inputbox "Default gateway:" 9 62 "${DHCP_GW:-192.168.1.1}")
HOST_IP="${STATIC_CIDR%%/*}"; PREFIX="${STATIC_CIDR##*/}"

DEFAULT_DNS=$(awk '/^nameserver/{printf "%s ", $2}' /etc/resolv.conf 2>/dev/null)
DEFAULT_DNS="${DEFAULT_DNS:-1.1.1.1 8.8.8.8}"
DNS=$(W --title " DNS Servers " --inputbox \
    "DNS servers (space separated):" 9 62 "${DEFAULT_DNS% }")
[[ -z "$DNS" ]] && DNS="1.1.1.1 8.8.8.8"

# ── 5. Optional ZFS storage pool ──────────────────────────────────────────
ZFS_SELECTED=(); ZFS_TOPO="stripe"
mapfile -t RAW_DISKS < <(lsblk -dno NAME,SIZE,TYPE 2>/dev/null | awk '$3=="disk"{print $1" "$2}')
if [[ ${#RAW_DISKS[@]} -gt 0 ]]; then
    ZARGS=()
    for entry in "${RAW_DISKS[@]}"; do
        dn="${entry%% *}"; ds="${entry##* }"
        # Don't offer the OS target disk for the data pool
        [[ "/dev/$dn" == "$DISK" ]] && continue
        ZARGS+=("$dn" "$ds" "OFF")
    done
    if [[ ${#ZARGS[@]} -gt 0 ]]; then
        ZFS_RAW=$(W --title " ZFS Storage Pool " --checklist \
            "Select disks for the VM/container storage pool.\n(Optional — skip with OK if unsure)" \
            18 62 8 "${ZARGS[@]}") || ZFS_RAW=""
        if [[ -n "$ZFS_RAW" ]]; then
            read -ra ZFS_SELECTED <<< "${ZFS_RAW//\"/}"
            if [[ ${#ZFS_SELECTED[@]} -ge 2 ]]; then
                ZFS_TOPO=$(W --title " ZFS Pool Topology " --menu "Select pool topology:" 13 62 3 \
                    "mirror" "Mirror (RAID-1, 2+ disks, redundant)" \
                    "raidz1" "RAIDZ1 (RAID-5, 3+ disks, parity)" \
                    "stripe" "Stripe (RAID-0, no redundancy)")
            fi
        fi
    fi
fi

# ── 6. Summary & confirm ──────────────────────────────────────────────────
ZFS_SUMMARY="None"
[[ ${#ZFS_SELECTED[@]} -gt 0 ]] && ZFS_SUMMARY="${ZFS_TOPO}: ${ZFS_SELECTED[*]}"

W --title " !! CONFIRM — DISK WILL BE ERASED !!" --yesno \
"The disk ${DISK} will be ERASED and DebDox installed with:\n\
\n\
  Disk      : ${DISK} (${BOOT_LABEL})\n\
  Locale    : ${LOCALE}\n\
  Keyboard  : ${KEYMAP}\n\
  Time zone : ${TIMEZONE}\n\
  Hostname  : ${HOSTNAME}\n\
  Interface : ${NET_IFACE}\n\
  IP address: ${HOST_IP}/${PREFIX}\n\
  Gateway   : ${GATEWAY}\n\
  DNS       : ${DNS}\n\
  Admin user: ${ADMIN_USER}\n\
  ZFS pool  : ${ZFS_SUMMARY}\n\
\n\
Proceed with installation?" 24 64

# ── 7. Install ────────────────────────────────────────────────────────────
dbx_run_install

clear
printf '\n  \033[1;32m✓  DebDox installed successfully!\033[0m\n\n'
printf '  After reboot, open:  \033[1;34mhttp://%s/\033[0m\n\n' "$HOST_IP"
printf '  Remove the installation media, then press Enter to reboot.\n\n'
read -r
reboot
