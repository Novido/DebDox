#!/usr/bin/env bash
# DebDox Installer вҖ” Terminal (plain text) mode.
# Same Proxmox-style single flow as the graphical installer, using plain
# prompts that work on serial consoles and minimal terminals.
set -euo pipefail

[[ $EUID -ne 0 ]] && { echo "Must run as root" >&2; exit 1; }

source /usr/local/lib/debdox/install-lib.sh

hr()  { printf '%0.sв”Җ' {1..60}; printf '\n'; }
hdr() { echo ""; hr; printf "  %s\n" "$1"; hr; }

# ask VAR "Prompt" "default"
ask() {
    local __var="$1" __prompt="$2" __def="${3:-}" __ans
    if [[ -n "$__def" ]]; then
        printf "  %s [%s]: " "$__prompt" "$__def"
    else
        printf "  %s: " "$__prompt"
    fi
    read -r __ans
    [[ -z "$__ans" ]] && __ans="$__def"
    printf -v "$__var" '%s' "$__ans"
}

# pick VAR "Prompt" "default" item1 item2 ...
pick() {
    local __var="$1" __prompt="$2" __def="$3"; shift 3
    local opts=("$@") i ans
    echo ""
    for i in "${!opts[@]}"; do printf "    %2d) %s\n" "$((i+1))" "${opts[$i]}"; done
    printf "  %s [%s]: " "$__prompt" "$__def"
    read -r ans
    if [[ "$ans" =~ ^[0-9]+$ ]] && (( ans >= 1 && ans <= ${#opts[@]} )); then
        printf -v "$__var" '%s' "${opts[$((ans-1))]%% *}"
    else
        printf -v "$__var" '%s' "$__def"
    fi
}

clear
cat <<'BANNER'

  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—
  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•қ
  в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв•”в•қ
  в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в–Ҳв–Ҳв•—
  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•—
  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қ
  Hypervisor Platform вҖ” Installer (Terminal UI)

BANNER

hdr "Welcome"
echo "  This wizard collects all settings, installs DebDox to disk,"
echo "  and reboots into a ready-to-use system."
echo ""
echo "  WARNING: The selected disk will be completely erased."
printf "\n  Press Enter to continue, or Ctrl+C to abort: "; read -r

# в”Җв”Җ 1. Target disk в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
hdr "Target Disk"
echo "  Available disks:"; echo ""
lsblk -dno NAME,SIZE,MODEL 2>/dev/null | while read -r name size model; do
    [[ "$name" == loop* || "$name" == sr* ]] && continue
    printf "    /dev/%-14s  %-8s  %s\n" "$name" "$size" "$model"
done
echo ""
while true; do
    ask DISK_NAME "Disk to install on (e.g. sda, nvme0n1)" ""
    DISK="/dev/${DISK_NAME}"
    [[ -b "$DISK" ]] && break
    echo "  ERROR: ${DISK} not found. Try again."
done
if [[ -d /sys/firmware/efi ]]; then BOOT_MODE="uefi"; BOOT_LABEL="UEFI"
else BOOT_MODE="bios"; BOOT_LABEL="BIOS (Legacy)"; fi

# в”Җв”Җ 2. Location & Time Zone в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
hdr "Location & Time Zone"
pick LOCALE "Select locale" "en_US.UTF-8" \
    "en_US.UTF-8 (English US)" "en_GB.UTF-8 (English UK)" "sv_SE.UTF-8 (Swedish)" \
    "nb_NO.UTF-8 (Norwegian)" "da_DK.UTF-8 (Danish)" "fi_FI.UTF-8 (Finnish)" \
    "de_DE.UTF-8 (German)" "fr_FR.UTF-8 (French)" "es_ES.UTF-8 (Spanish)" \
    "it_IT.UTF-8 (Italian)" "nl_NL.UTF-8 (Dutch)"

pick KEYMAP "Select keyboard layout" "us" \
    "us (English US)" "gb (English UK)" "se (Swedish)" "no (Norwegian)" \
    "dk (Danish)" "fi (Finnish)" "de (German)" "fr (French)" \
    "es (Spanish)" "it (Italian)" "nl (Dutch)"
loadkeys "$KEYMAP" 2>/dev/null || true

pick TIMEZONE "Select time zone" "UTC" \
    "Europe/Stockholm" "Europe/Oslo" "Europe/Copenhagen" "Europe/Helsinki" \
    "Europe/Berlin" "Europe/London" "Europe/Paris" "Europe/Madrid" \
    "Europe/Rome" "Europe/Amsterdam" "America/New_York" "America/Chicago" \
    "America/Los_Angeles" "UTC"
[[ -f "/usr/share/zoneinfo/${TIMEZONE}" ]] || TIMEZONE="UTC"

# в”Җв”Җ 3. Administration password в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
hdr "Administration"
ask ADMIN_USER "Admin username for the web UI" "admin"
while true; do
    printf "  Password for '%s': " "$ADMIN_USER"; read -rs PASS1; echo ""
    printf "  Confirm password: "; read -rs PASS2; echo ""
    [[ -n "$PASS1" && "$PASS1" == "$PASS2" ]] && break
    echo "  Passwords do not match or are empty. Try again."
done
ADMIN_PASS="$PASS1"

# в”Җв”Җ 4. Management network в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
hdr "Management Network"
ask HOSTNAME "System hostname (FQDN or short name)" "debdox.local"

IFACES=()
while IFS= read -r iface; do IFACES+=("$iface"); done \
    < <(ls /sys/class/net/ | grep -Ev '^(lo|docker|virbr|veth|vmbr|bond|dummy)')
[[ ${#IFACES[@]} -eq 0 ]] && { echo "  ERROR: no network interfaces found."; exit 1; }
pick NET_IFACE "Select management interface" "${IFACES[0]}" "${IFACES[@]}"

DHCP_CIDR=$(ip -4 addr show "$NET_IFACE" 2>/dev/null | awk '/inet /{print $2}' | head -1 || true)
DHCP_ADDR="${DHCP_CIDR%%/*}"; DHCP_PREFIX="${DHCP_CIDR##*/}"
DHCP_GW=$(ip route 2>/dev/null | awk '/^default/{print $3}' | head -1 || true)

ask STATIC_CIDR "Static IP in CIDR (e.g. 192.168.1.100/24)" "${DHCP_ADDR:-192.168.1.100}/${DHCP_PREFIX:-24}"
HOST_IP="${STATIC_CIDR%%/*}"; PREFIX="${STATIC_CIDR##*/}"
ask GATEWAY "Default gateway" "${DHCP_GW:-192.168.1.1}"

DEFAULT_DNS=$(awk '/^nameserver/{printf "%s ", $2}' /etc/resolv.conf 2>/dev/null)
DEFAULT_DNS="${DEFAULT_DNS:-1.1.1.1 8.8.8.8}"
ask DNS "DNS servers (space separated)" "${DEFAULT_DNS% }"

# в”Җв”Җ 5. Optional ZFS storage pool в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
hdr "ZFS Storage Pool (optional)"
ZFS_SELECTED=(); ZFS_TOPO="stripe"
echo "  Available data disks (excluding the OS disk):"
AVAIL=()
while read -r name size type; do
    [[ "$type" == "disk" ]] || continue
    [[ "/dev/$name" == "$DISK" ]] && continue
    AVAIL+=("$name"); printf "    %-12s %s\n" "$name" "$size"
done < <(lsblk -dno NAME,SIZE,TYPE 2>/dev/null)
if [[ ${#AVAIL[@]} -gt 0 ]]; then
    echo ""
    ask ZSEL "Disks for storage pool (space separated, blank to skip)" ""
    if [[ -n "$ZSEL" ]]; then
        read -ra ZFS_SELECTED <<< "$ZSEL"
        if [[ ${#ZFS_SELECTED[@]} -ge 2 ]]; then
            pick ZFS_TOPO "Pool topology" "stripe" "mirror" "raidz1" "stripe"
        fi
    fi
else
    echo "  (none)"
fi

# в”Җв”Җ 6. Summary & confirm в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
ZFS_SUMMARY="None"
[[ ${#ZFS_SELECTED[@]} -gt 0 ]] && ZFS_SUMMARY="${ZFS_TOPO}: ${ZFS_SELECTED[*]}"
hdr "!! CONFIRM вҖ” DISK WILL BE ERASED !!"
echo "  Disk      : ${DISK} (${BOOT_LABEL})"
echo "  Locale    : ${LOCALE}"
echo "  Keyboard  : ${KEYMAP}"
echo "  Time zone : ${TIMEZONE}"
echo "  Hostname  : ${HOSTNAME}"
echo "  Interface : ${NET_IFACE}"
echo "  IP address: ${HOST_IP}/${PREFIX}"
echo "  Gateway   : ${GATEWAY}"
echo "  DNS       : ${DNS}"
echo "  Admin user: ${ADMIN_USER}"
echo "  ZFS pool  : ${ZFS_SUMMARY}"
echo ""
printf "  Type 'yes' to erase %s and install: " "$DISK"; read -r CONFIRM
[[ "$CONFIRM" == "yes" ]] || { echo "  Installation aborted."; exit 1; }

# в”Җв”Җ 7. Install в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
dbx_run_install

echo ""
echo "  вң“  DebDox installed successfully!"
echo ""
echo "  After reboot, open:  http://${HOST_IP}/"
echo ""

# In debug mode, return to the debug wrapper instead of rebooting so the
# post-install shell can inspect /target and the install log.
if [[ "${DEBDOX_DEBUG:-0}" == "1" ]]; then
    echo "  (debug mode: returning to debug shell, no reboot)"
    exit 0
fi

echo "  Remove the installation media, then press Enter to reboot."
echo ""
read -r
reboot
