#!/usr/bin/env bash
# DebDox first-run setup wizard — Proxmox-style.
# Runs once on first boot after installation. Collects and applies all
# vital settings: locale, keyboard, timezone, hostname, network, DNS,
# admin account and an optional ZFS storage pool.
set -euo pipefail

FLAG="/etc/debdox/.configured"
[[ -f "$FLAG" ]] && exit 0

CONF="/etc/debdox"
mkdir -p "$CONF"

# whiptail helper: redirect stderr→stdout so we can capture the selection
W() { whiptail "$@" 3>&1 1>&2 2>&3; }

clear
printf '\n'
printf '  \033[1;36m██████╗ ███████╗██████╗ ██████╗  ██████╗ ██╗  ██╗\033[0m\n'
printf '  \033[1;36m██╔══██╗██╔════╝██╔══██╗██╔══██╗██╔═══██╗╚██╗██╔╝\033[0m\n'
printf '  \033[1;36m██║  ██║█████╗  ██████╔╝██║  ██║██║   ██║ ╚███╔╝ \033[0m\n'
printf '  \033[1;36m██║  ██║██╔══╝  ██╔══██╗██║  ██║██║   ██║ ██╔██╗ \033[0m\n'
printf '  \033[1;36m██████╔╝███████╗██████╔╝██████╔╝╚██████╔╝██╔╝ ██╗\033[0m\n'
printf '  \033[1;36m╚═════╝ ╚══════╝╚═════╝ ╚═════╝  ╚═════╝ ╚═╝  ╚═╝\033[0m\n'
printf '\n'
sleep 1

# ── 1. Welcome ────────────────────────────────────────────────────────────
W --title " DebDox First-Run Setup " --msgbox \
"Welcome to DebDox — Hypervisor Platform\n\
\n\
This wizard will configure:\n\
\n\
  • Language / locale and keyboard layout\n\
  • Time zone\n\
  • Hostname and management network\n\
  • Admin password (console + web UI)\n\
  • ZFS storage pool (optional)\n\
\n\
Setup takes about 2 minutes. Press OK to begin." 18 64

# ── 2. Locale / language ──────────────────────────────────────────────────
LOCALE=$(W --title " Language / Locale " \
    --menu "Select the system language and locale:" 20 64 11 \
    "en_US.UTF-8" "English (United States)" \
    "en_GB.UTF-8" "English (United Kingdom)" \
    "sv_SE.UTF-8" "Swedish (Sweden)" \
    "nb_NO.UTF-8" "Norwegian Bokmal (Norway)" \
    "da_DK.UTF-8" "Danish (Denmark)" \
    "fi_FI.UTF-8" "Finnish (Finland)" \
    "de_DE.UTF-8" "German (Germany)" \
    "fr_FR.UTF-8" "French (France)" \
    "es_ES.UTF-8" "Spanish (Spain)" \
    "it_IT.UTF-8" "Italian (Italy)" \
    "nl_NL.UTF-8" "Dutch (Netherlands)") || LOCALE="en_US.UTF-8"
[[ -z "$LOCALE" ]] && LOCALE="en_US.UTF-8"

# ── 3. Keyboard layout ────────────────────────────────────────────────────
KEYMAP=$(W --title " Keyboard Layout " \
    --menu "Select the keyboard layout:" 20 64 11 \
    "us" "English (US)" \
    "gb" "English (UK)" \
    "se" "Swedish" \
    "no" "Norwegian" \
    "dk" "Danish" \
    "fi" "Finnish" \
    "de" "German" \
    "fr" "French" \
    "es" "Spanish" \
    "it" "Italian" \
    "nl" "Dutch") || KEYMAP="us"
[[ -z "$KEYMAP" ]] && KEYMAP="us"

# Apply the keyboard immediately so the admin password is typed correctly
loadkeys "$KEYMAP" 2>/dev/null || true

# ── 4. Time zone ──────────────────────────────────────────────────────────
TZSEL=$(W --title " Time Zone " \
    --menu "Select the system time zone:" 22 64 14 \
    "Europe/Stockholm"    "Sweden" \
    "Europe/Oslo"         "Norway" \
    "Europe/Copenhagen"   "Denmark" \
    "Europe/Helsinki"     "Finland" \
    "Europe/Berlin"       "Germany / Central Europe" \
    "Europe/London"       "United Kingdom" \
    "Europe/Paris"        "France" \
    "Europe/Madrid"       "Spain" \
    "Europe/Rome"         "Italy" \
    "Europe/Amsterdam"    "Netherlands" \
    "America/New_York"    "US Eastern" \
    "America/Chicago"     "US Central" \
    "America/Los_Angeles" "US Pacific" \
    "UTC"                 "Coordinated Universal Time" \
    "Other"               "Enter manually...") || TZSEL="UTC"

if [[ "$TZSEL" == "Other" ]]; then
    TIMEZONE=$(W --title " Time Zone " --inputbox \
        "Enter the time zone (e.g. Europe/Stockholm):" 9 62 "UTC")
    [[ -z "$TIMEZONE" ]] && TIMEZONE="UTC"
else
    TIMEZONE="$TZSEL"
fi
# Validate; fall back to UTC if the zone file does not exist
[[ -f "/usr/share/zoneinfo/${TIMEZONE}" ]] || TIMEZONE="UTC"

# ── 5. Hostname ───────────────────────────────────────────────────────────
HOSTNAME=$(W --title " Hostname " --inputbox \
    "System hostname (FQDN or short name):" 9 62 "debdox.local")
[[ -z "$HOSTNAME" ]] && HOSTNAME="debdox.local"
HOST_SHORT="${HOSTNAME%%.*}"

# ── 6. Network interface ──────────────────────────────────────────────────
IFACE_ARGS=()
while IFS= read -r iface; do
    mac=$(cat "/sys/class/net/$iface/address" 2>/dev/null || echo "??:??:??:??:??:??")
    IFACE_ARGS+=("$iface" "[$mac]")
done < <(ls /sys/class/net/ | grep -Ev '^(lo|docker|virbr|veth|vmbr|bond|dummy)')

if [[ ${#IFACE_ARGS[@]} -eq 0 ]]; then
    W --title " Error " --msgbox \
        "No physical network interfaces found.\nCheck hardware and try again." 9 55
    exit 1
fi

NET_IFACE=$(W --title " Network Interface " \
    --menu "Select the management network interface:" 16 62 8 \
    "${IFACE_ARGS[@]}")

# ── 7. Static IP configuration ────────────────────────────────────────────
# Try to pre-fill with any address currently obtained via DHCP
DHCP_CIDR=$(ip -4 addr show "$NET_IFACE" 2>/dev/null \
    | awk '/inet /{print $2}' | head -1 || true)
DHCP_ADDR="${DHCP_CIDR%%/*}"
DHCP_PREFIX="${DHCP_CIDR##*/}"
DHCP_GW=$(ip route 2>/dev/null | awk '/^default/{print $3}' | head -1 || true)

STATIC_CIDR=$(W --title " IP Address " \
    --inputbox \
    "Static IP address in CIDR notation:\n(e.g. 192.168.1.100/24)" \
    11 62 "${DHCP_ADDR:-192.168.1.100}/${DHCP_PREFIX:-24}")

GATEWAY=$(W --title " Default Gateway " \
    --inputbox "Default gateway:" 9 62 "${DHCP_GW:-192.168.1.1}")

HOST_IP="${STATIC_CIDR%%/*}"
PREFIX="${STATIC_CIDR##*/}"

# ── 8. DNS servers ────────────────────────────────────────────────────────
DEFAULT_DNS=$(awk '/^nameserver/{printf "%s ", $2}' /etc/resolv.conf 2>/dev/null)
DEFAULT_DNS="${DEFAULT_DNS:-1.1.1.1 8.8.8.8}"
DNS=$(W --title " DNS Servers " --inputbox \
    "DNS servers (space separated):" 9 62 "${DEFAULT_DNS% }")
[[ -z "$DNS" ]] && DNS="1.1.1.1 8.8.8.8"

# ── 9. Admin account ──────────────────────────────────────────────────────
ADMIN_USER=$(W --title " Admin Account " \
    --inputbox "Admin username for the web UI:" 9 62 "admin")
[[ -z "$ADMIN_USER" ]] && ADMIN_USER="admin"

while true; do
    PASS1=$(W --title " Admin Password " \
        --passwordbox "Set the password for '${ADMIN_USER}':" 9 62)
    PASS2=$(W --title " Admin Password " \
        --passwordbox "Confirm password:" 9 62)
    if [[ -n "$PASS1" && "$PASS1" == "$PASS2" ]]; then
        break
    fi
    W --title " Error " --msgbox \
        "Passwords do not match or are empty.\nPlease try again." 9 55
done

# ── 10. ZFS storage pool (optional) ───────────────────────────────────────
ZFS_SELECTED=()
ZFS_TOPO="stripe"

mapfile -t RAW_DISKS < <(lsblk -dno NAME,SIZE,TYPE 2>/dev/null \
    | awk '$3=="disk"{print $1" "$2}')

if [[ ${#RAW_DISKS[@]} -gt 0 ]]; then
    DISK_ARGS=()
    for entry in "${RAW_DISKS[@]}"; do
        dname="${entry%% *}"
        dsize="${entry##* }"
        DISK_ARGS+=("$dname" "$dsize" "OFF")
    done

    ZFS_RAW=$(W --title " ZFS Storage Pool " \
        --checklist \
        "Select disks for the VM/container storage pool.\n(Space to select, optional — skip with OK if unsure)" \
        18 62 8 "${DISK_ARGS[@]}") || ZFS_RAW=""

    if [[ -n "$ZFS_RAW" ]]; then
        # Remove quotes that whiptail adds around each item
        ZFS_CLEAN="${ZFS_RAW//\"/}"
        read -ra ZFS_SELECTED <<< "$ZFS_CLEAN"

        if [[ ${#ZFS_SELECTED[@]} -ge 2 ]]; then
            ZFS_TOPO=$(W --title " ZFS Pool Topology " \
                --menu "Select pool topology:" 13 62 3 \
                "mirror" "Mirror (RAID-1, needs 2+ disks, redundant)" \
                "raidz1" "RAIDZ1 (RAID-5, needs 3+ disks, parity)" \
                "stripe" "Stripe (RAID-0, no redundancy, max capacity)")
        fi
    fi
fi

# ── 11. Confirm and apply ─────────────────────────────────────────────────
ZFS_SUMMARY="None"
if [[ ${#ZFS_SELECTED[@]} -gt 0 ]]; then
    ZFS_SUMMARY="${ZFS_TOPO}: ${ZFS_SELECTED[*]}"
fi

W --title " Confirm Settings " --yesno \
"Apply the following configuration?\n\
\n\
  Locale    : ${LOCALE}\n\
  Keyboard  : ${KEYMAP}\n\
  Time zone : ${TIMEZONE}\n\
  Hostname  : ${HOSTNAME}\n\
  Interface : ${NET_IFACE}\n\
  IP address: ${HOST_IP}/${PREFIX}\n\
  Gateway   : ${GATEWAY}\n\
  DNS       : ${DNS}\n\
  Admin user: ${ADMIN_USER}\n\
  ZFS pool  : ${ZFS_SUMMARY}\n" \
21 62

clear
echo ""
echo "Applying configuration, please wait..."
echo ""

# ── Locale ────────────────────────────────────────────────────────────────
echo "Setting locale (${LOCALE})..."
if grep -qE "^#? *${LOCALE} UTF-8" /etc/locale.gen 2>/dev/null; then
    sed -i "s/^#\? *${LOCALE} UTF-8/${LOCALE} UTF-8/" /etc/locale.gen
else
    echo "${LOCALE} UTF-8" >> /etc/locale.gen
fi
locale-gen >/dev/null 2>&1 || true
update-locale LANG="${LOCALE}" >/dev/null 2>&1 || true

# ── Keyboard ──────────────────────────────────────────────────────────────
echo "Setting keyboard layout (${KEYMAP})..."
cat > /etc/default/keyboard <<EOF
XKBMODEL="pc105"
XKBLAYOUT="${KEYMAP}"
XKBVARIANT=""
XKBOPTIONS=""
BACKSPACE="guess"
EOF
setupcon --save 2>/dev/null || true
loadkeys "${KEYMAP}" 2>/dev/null || true

# ── Time zone ─────────────────────────────────────────────────────────────
echo "Setting time zone (${TIMEZONE})..."
ln -sf "/usr/share/zoneinfo/${TIMEZONE}" /etc/localtime
echo "${TIMEZONE}" > /etc/timezone
timedatectl set-timezone "${TIMEZONE}" 2>/dev/null || true

# ── Hostname ──────────────────────────────────────────────────────────────
echo "Setting hostname (${HOSTNAME})..."
echo "${HOST_SHORT}" > /etc/hostname
hostnamectl set-hostname "${HOST_SHORT}" 2>/dev/null || true
cat > /etc/hosts <<EOF
127.0.0.1   localhost
127.0.1.1   ${HOSTNAME} ${HOST_SHORT}
::1         localhost ip6-localhost ip6-loopback
EOF

# ── Network — fill in the template placed by 06-network.sh ────────────────
echo "Configuring network..."
TMPL="/etc/network/interfaces.debdox-template"
if [[ -f "$TMPL" ]]; then
    sed \
        -e "s|__IFACE__|${NET_IFACE}|g" \
        -e "s|__HOST_IP__|${HOST_IP}|g" \
        -e "s|__PREFIX__|${PREFIX}|g" \
        -e "s|__GATEWAY__|${GATEWAY}|g" \
        -e "s|__DNS__|${DNS}|g" \
        "$TMPL" > /etc/network/interfaces
else
    cat > /etc/network/interfaces <<EOF
auto lo
iface lo inet loopback

auto ${NET_IFACE}
iface ${NET_IFACE} inet manual

auto vmbr0
iface vmbr0 inet static
    address ${HOST_IP}/${PREFIX}
    gateway ${GATEWAY}
    dns-nameservers ${DNS}
    bridge-ports ${NET_IFACE}
    bridge-stp off
    bridge-fd 0
    bridge-maxwait 0
EOF
fi

# DNS — write resolv.conf directly so name resolution works without resolvconf
: > /etc/resolv.conf
for ns in ${DNS}; do
    echo "nameserver ${ns}" >> /etc/resolv.conf
done

# ── Admin / system passwords ──────────────────────────────────────────────
echo "Setting passwords..."
echo "root:${PASS1}" | chpasswd

# ── DebDox API config ─────────────────────────────────────────────────────
mkdir -p /opt/debdox/data
cat > "${CONF}/api.env" <<EOF
SECRET_KEY=$(python3 -c "import secrets; print(secrets.token_hex(32))")
DEBDOX_ADMIN_USERNAME=${ADMIN_USER}
DEBDOX_ADMIN_PASSWORD=${PASS1}
DB_URL=sqlite:////opt/debdox/data/debdox.db
EOF
chmod 600 "${CONF}/api.env"

# Persist system settings for the welcome banner and the web UI
cat > "${CONF}/system.conf" <<EOF
LOCALE=${LOCALE}
KEYMAP=${KEYMAP}
TIMEZONE=${TIMEZONE}
HOSTNAME=${HOSTNAME}
NET_IFACE=${NET_IFACE}
HOST_IP=${HOST_IP}
PREFIX=${PREFIX}
GATEWAY=${GATEWAY}
DNS=${DNS}
EOF
echo "${HOST_IP}" > "${CONF}/host_ip"

# ── ZFS pool ──────────────────────────────────────────────────────────────
if [[ ${#ZFS_SELECTED[@]} -gt 0 ]]; then
    echo "Creating ZFS pool (${ZFS_TOPO})..."
    DISK_DEVS=()
    for d in "${ZFS_SELECTED[@]}"; do
        DISK_DEVS+=("/dev/${d}")
    done
    if [[ "$ZFS_TOPO" == "stripe" ]]; then
        zpool create -f debdox-data "${DISK_DEVS[@]}" 2>/dev/null || true
    else
        zpool create -f debdox-data "$ZFS_TOPO" "${DISK_DEVS[@]}" 2>/dev/null || true
    fi
    zfs create -p debdox-data/vms       2>/dev/null || true
    zfs create -p debdox-data/containers 2>/dev/null || true
    zfs create -p debdox-data/backups   2>/dev/null || true
    echo "ZFS pool created."
fi

# ── Bring up the bridge ───────────────────────────────────────────────────
echo "Bringing up network..."
ifdown vmbr0 2>/dev/null || true
ifup vmbr0   2>/dev/null || true

# ── Start DebDox services ─────────────────────────────────────────────────
echo "Starting services..."
systemctl restart debdox-ui debdox-api debdox-agent debdox-mcp 2>/dev/null || true

# Mark as configured so this wizard never runs again
touch "$FLAG"

# Disable auto-login now that the system is set up
rm -f /etc/systemd/system/getty@tty1.service.d/autologin.conf
systemctl daemon-reload 2>/dev/null || true

echo ""
echo "Configuration complete."
sleep 1

exec /usr/local/bin/debdox-welcome
